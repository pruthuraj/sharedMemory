{
  "name": "mcp-shared-memory-server",
  "version": "0.1.0",
  "description": "Local shared-memory service with WebSocket coordination and stdio MCP tools",
  "main": "server.js",
  "scripts": {
    "doctor": "node scripts/shared-memory-doctor.js",
    "mcp": "node mcp-server.mjs",
    "restart": "node scripts/restart-server.js",
    "smoke:suggest": "node scripts/smoke-suggest.js",
    "start": "node --env-file=.env server.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "express": "^4.18.2",
    "ws": "^8.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
